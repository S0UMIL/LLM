   "id": "ec0afedc",
   "metadata": {},
   "outputs": [],
   "source": [
    "llm=OllamaLLM(model='llama3.2',temperature=0.7)\n",
    "prompt = PromptTemplate(\n",
    "    input_variables=['question', 'context'],\n",
    "    template=\"Context:\\n{context}\\n\\nQuestion: {question}\\nAnswer based only on the context above.\"\n",
    ")\n",
    "\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 216,
   "id": "8d5c667e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def retrieve_answer(query):\n",
    "    doc_search=retrieve_query(query)\n",
    "    print(doc_search)\n",
    "    context=\"\\n\".join([documents.page_content for documents in  doc_search])\n",
    "    chain= prompt | llm\n",
    "    print(context)\n",
    "    return chain.invoke({\"context\":context,\"question\":query})\n"
   ]
